# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ADMIN_PASSWORD: Password protecting the Command Center/Admin Panel edits
ADMIN_PASSWORD="admin123"

# BLOB_READ_WRITE_TOKEN: Vercel Blob Storage token for persistent profile image.
# Created automatically when you add a Blob Store in Vercel Dashboard → Storage.
# Not needed for local development (images are saved to filesystem locally).
BLOB_READ_WRITE_TOKEN=""
